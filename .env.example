# ============================================================
# EduSafe · Variables de entorno
# Copiar a .env y completar con los valores reales
# NUNCA commitear el .env al repositorio
# ============================================================

# Supabase (obtener en: Project Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Solo para Edge Functions (nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=...

# Email transaccional (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM=alertas@edusafe.app

# IA Triaje (Sprint 7)
OPENAI_API_KEY=sk-xxx
TRIAGE_MODEL=gpt-4o-mini

# Hosting
VITE_APP_URL=https://app.edusafe.app
VITE_VERIFY_URL=https://verify.edusafe.app

# Monitoring
VITE_SENTRY_DSN=https://...@sentry.io/...

# Storage buckets (ya configurados en Supabase)
# SUPABASE_STORAGE_BUCKET_ACTAS=actas
# SUPABASE_STORAGE_BUCKET_EVIDENCE=evidence

# Seguridad
EMOJI_HASH_SALT=cambiar-por-valor-aleatorio-seguro

# Feature flags
VITE_FEATURE_AI_TRIAGE=false
VITE_FEATURE_PUSH_NOTIFICATIONS=false
VITE_FEATURE_BILINGUAL_VAL=false
